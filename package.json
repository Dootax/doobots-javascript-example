{
  "name": "doobots-javascript-example",
  "version": "1.0.0",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest",
    "local": "cpx \"input.json\" dist && cpx \"src/**/*.js\" dist && doobots-run",
    "package": "doobots-package"
  },
  "dependencies": {
    "doobots": "^1.0.4"
  },
  "devDependencies": {
    "cpx2": "^8.0.0",
    "cross-env": "^10.0.0",
    "jest": "^30.1.0"
  },
  "keywords": [
    "dooBots",
    "javascript",
    "example"
  ],
  "overrides": {
    "test-exclude": "^7.0.1",
    "glob": "^11.0.3"
  },
  "author": "Dootax",
  "license": "MIT",
  "description": "Exemplo de script JavaScript para ser executado no DooBots"
}
